<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@android:color/transparent"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <ScrollView
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:scrollbars="vertical"
        android:paddingEnd="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dirman_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Files"
                android:textColor="@color/primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dirman_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="-"
                android:textColor="@color/secondary_text"
                android:textSize="11sp"
                android:clickable="true"
                android:ellipsize="start"
                android:singleLine="true" />

            <LinearLayout
                android:id="@+id/dirman_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <com.kdt.mcgui.MineButton
                    android:id="@+id/dirman_up"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Up" />

                <com.kdt.mcgui.MineButton
                    android:id="@+id/dirman_upload"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:text="Upload" />

                <com.kdt.mcgui.MineButton
                    android:id="@+id/dirman_new_folder"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:text="New folder" />

                <com.kdt.mcgui.MineButton
                    android:id="@+id/dirman_rename"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:text="Rename" />

                <com.kdt.mcgui.MineButton
                    android:id="@+id/dirman_delete"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:text="Delete" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.kdt.mcgui.MineButton
                        android:id="@+id/dirman_scroll_top"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Top" />

                    <com.kdt.mcgui.MineButton
                        android:id="@+id/dirman_scroll_bottom"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Bottom" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/dirman_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text=""
                android:textColor="@color/secondary_text"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dirman_list"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:clipToPadding="false"
        android:paddingBottom="6dp" />

</LinearLayout>
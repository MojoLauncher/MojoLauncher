<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050816">

    <!-- BACKGROUND -->

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050816"/>

    <!-- SIDEBAR -->

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="78dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="top|center_horizontal"
        android:paddingTop="24dp"
        android:background="#0B1220"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="26dp"
            android:src="@mipmap/ic_launcher"/>

        <ImageButton
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:src="@drawable/ic_px_folder"
            app:tint="#00E5FF"
            android:background="@drawable/card_bg"/>

        <ImageButton
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_px_gamepad"
            app:tint="#FFFFFF"
            android:background="@drawable/card_bg"/>

        <ImageButton
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_px_java_run"
            app:tint="#FFFFFF"
            android:background="@drawable/card_bg"/>

    </LinearLayout>

    <!-- TOP BAR -->

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="#0F172A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CRAZE LAUNCHER"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- MAIN CONTENT -->

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_panel"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- HERO CARD -->

            <LinearLayout
                android:id="@+id/game_panel"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:padding="24dp"
                android:background="@drawable/card_bg">

                <ImageView
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:src="@mipmap/ic_launcher"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/game_title"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/game_desc"
                    android:textColor="#9FB0CC"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- SECTION TITLE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <!-- FIRST ROW -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/custom_control_button"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:drawableTop="@drawable/ic_px_gamepad"
                    android:text="@string/mcl_option_customcontrol"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="@drawable/card_bg"/>

                <Button
                    android:id="@+id/install_jar_button"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:drawableTop="@drawable/ic_px_java_run"
                    android:text="@string/main_install_jar_file"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="@drawable/card_bg"/>

            </LinearLayout>

            <!-- SECOND ROW -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/share_logs_button"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:drawableTop="@drawable/ic_px_sharelog"
                    android:text="@string/main_share_logs"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="@drawable/card_bg"/>

                <Button
                    android:id="@+id/open_files_button"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:drawableTop="@drawable/ic_px_folder"
                    android:text="@string/mcl_button_open_directory"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="@drawable/card_bg"/>

            </LinearLayout>

            <!-- FULL BUTTONS -->

            <Button
                android:id="@+id/news_button"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="24dp"
                android:drawableStart="@drawable/ic_px_book"
                android:text="@string/mcl_tab_wiki"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingStart="20dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_bg"/>

            <Button
                android:id="@+id/social_media_button"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="14dp"
                android:drawableStart="@drawable/ic_social_media"
                android:text="@string/mcl_button_social_media"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingStart="20dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_bg"/>

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM PANEL -->

    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="#0F172A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <com.kdt.mcgui.mcVersionSpinner
            android:id="@+id/mc_version_spinner"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="@drawable/card_bg"
            android:paddingHorizontal="18dp"/>

        <ImageButton
            android:id="@+id/edit_profile_button"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="14dp"
            android:src="@drawable/ic_px_edit"
            app:tint="#00E5FF"
            android:background="@drawable/card_bg"/>

    </LinearLayout>

    <!-- FLOATING PLAY BUTTON -->

    <com.kdt.mcgui.MineButton
        android:id="@+id/play_button"
        android:layout_width="240dp"
        android:layout_height="68dp"
        android:layout_marginBottom="100dp"
        android:text="@string/main_play"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="18sp"
        android:background="@drawable/play_button_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

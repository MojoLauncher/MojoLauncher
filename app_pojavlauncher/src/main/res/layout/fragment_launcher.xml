<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050816">

    <!-- Background -->

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050816"/>

    <!-- Sidebar -->

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="top|center"
        android:paddingTop="28dp"
        android:background="#101826"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="28dp"/>

        <ImageButton
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/ic_px_folder"
            app:tint="#00E5FF"
            android:background="#162033"/>

        <ImageButton
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_px_gamepad"
            app:tint="#FFFFFF"
            android:background="#162033"/>

        <ImageButton
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_px_java_run"
            app:tint="#FFFFFF"
            android:background="#162033"/>

    </LinearLayout>

    <!-- Top Bar -->

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="22dp"
        android:background="#101826"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CRAZE LAUNCHER"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Main Content -->

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_panel"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Hero Card -->

            <LinearLayout
                android:id="@+id/game_panel"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:padding="24dp"
                android:background="#162033">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@mipmap/ic_launcher"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/game_title"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/game_desc"
                    android:textColor="#9FB0CC"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Dashboard -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <!-- First Row -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.kdt.mcgui.LauncherMenuButton
                    android:id="@+id/custom_control_button"
                    style="@style/LauncherMenuButton.Universal"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:drawableTop="@drawable/ic_px_gamepad"
                    android:text="@string/mcl_option_customcontrol"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#162033"/>

                <com.kdt.mcgui.LauncherMenuButton
                    android:id="@+id/install_jar_button"
                    style="@style/LauncherMenuButton.Universal"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:drawableTop="@drawable/ic_px_java_run"
                    android:text="@string/main_install_jar_file"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#162033"/>

            </LinearLayout>

            <!-- Second Row -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.kdt.mcgui.LauncherMenuButton
                    android:id="@+id/share_logs_button"
                    style="@style/LauncherMenuButton.Universal"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:drawableTop="@drawable/ic_px_sharelog"
                    android:text="@string/main_share_logs"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#162033"/>

                <com.kdt.mcgui.LauncherMenuButton
                    android:id="@+id/open_files_button"
                    style="@style/LauncherMenuButton.Universal"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:drawableTop="@drawable/ic_px_folder"
                    android:text="@string/mcl_button_open_directory"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#162033"/>

            </LinearLayout>

            <!-- Top Buttons -->

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/news_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="24dp"
                android:drawableStart="@drawable/ic_px_book"
                android:text="@string/mcl_tab_wiki"
                android:textColor="#FFFFFF"
                android:paddingStart="18dp"
                android:background="#162033"/>

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/social_media_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="14dp"
                android:drawableStart="@drawable/ic_social_media"
                android:text="@string/mcl_button_social_media"
                android:textColor="#FFFFFF"
                android:paddingStart="18dp"
                android:background="#162033"/>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Panel -->

    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="#101826"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <com.kdt.mcgui.mcVersionSpinner
            android:id="@+id/mc_version_spinner"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_weight="1"
            android:background="#162033"
            android:paddingHorizontal="18dp"/>

        <ImageButton
            android:id="@+id/edit_profile_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="14dp"
            android:src="@drawable/ic_px_edit"
            app:tint="#00E5FF"
            android:background="#162033"/>

    </LinearLayout>

    <!-- Floating Play Button -->

    <com.kdt.mcgui.MineButton
        android:id="@+id/play_button"
        android:layout_width="220dp"
        android:layout_height="64dp"
        android:layout_marginBottom="100dp"
        android:text="@string/main_play"
        android:textColor="#050816"
        android:textStyle="bold"
        android:textSize="18sp"
        android:backgroundTint="#00E5FF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

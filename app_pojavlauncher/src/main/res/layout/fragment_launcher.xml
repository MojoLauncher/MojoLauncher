<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <!-- Main Scroll -->
    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_section">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.kdt.mcgui.LauncherMenuButton
                    android:id="@+id/news_button"
                    style="@style/LauncherMenuButton.Universal"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/mcl_tab_wiki"
                    android:drawableStart="@drawable/ic_px_book"
                    android:background="@drawable/card_background"
                    android:textColor="@color/primary_text"/>

                <com.kdt.mcgui.LauncherMenuButton
                    android:id="@+id/social_media_button"
                    style="@style/LauncherMenuButton.Universal"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/mcl_button_social_media"
                    android:drawableStart="@drawable/ic_social_media"
                    android:background="@drawable/card_background"
                    android:textColor="@color/primary_text"/>
            </LinearLayout>

            <!-- Premium Game Panel -->
            <LinearLayout
                   android:id="@+id/game_panel"
                   android:layout_width="match_parent"
                   android:layout_height="220dp"
                   android:layout_marginTop="18dp"
                   android:orientation="vertical"
                   android:background="@drawable/card_background"
                   android:padding="20dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/game_icon"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@mipmap/ic_launcher"/>

                    <TextView
                        android:id="@+id/game_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/game_icon"
                        android:layout_marginStart="16dp"
                        android:text="@string/game_title"
                        android:textColor="@color/primary_text"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/game_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/game_title"
                        android:layout_toEndOf="@id/game_icon"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/game_desc"
                        android:textColor="@color/secondary_text"
                        android:textSize="14sp"/>

                </RelativeLayout>
			</LinearLayout>
            </androidx.cardview.widget.CardView>
		    <LinearLayout

            <!-- Menu Buttons -->
            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/custom_control_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="18dp"
                android:drawableStart="@drawable/ic_px_gamepad"
                android:text="@string/mcl_option_customcontrol"
                android:background="@drawable/card_background"
                android:textColor="@color/primary_text"/>

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/install_jar_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="10dp"
                android:drawableStart="@drawable/ic_px_java_run"
                android:text="@string/main_install_jar_file"
                android:background="@drawable/card_background"
                android:textColor="@color/primary_text"/>

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/share_logs_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="10dp"
                android:drawableStart="@drawable/ic_px_sharelog"
                android:text="@string/main_share_logs"
                android:background="@drawable/card_background"
                android:textColor="@color/primary_text"/>
			<com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/open_files_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="10dp"
                android:drawableStart="@drawable/ic_px_folder"
                android:text="@string/mcl_button_open_directory"
                android:background="@drawable/card_background"
                android:textColor="@color/primary_text"/>

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/mod_manager_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="10dp"
                android:drawableStart="@drawable/ic_px_folder"
                android:text="Mods"
                android:background="@drawable/card_background"
                android:textColor="@color/primary_text"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Premium Section -->
    <LinearLayout
        android:id="@+id/bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/background_bottom_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Version + Edit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.kdt.mcgui.mcVersionSpinner
                android:id="@+id/mc_version_spinner"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/card_background"
                android:drawableEnd="@drawable/spinner_arrow"
                app:drawableEndSize="20dp"
                app:drawableStartSize="32dp"/>

            <ImageButton
                android:id="@+id/edit_profile_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/circle_button"
                android:src="@drawable/ic_px_edit"/>
        </LinearLayout>

        <!-- Premium Play Button -->
        <com.kdt.mcgui.MineButton
            android:id="@+id/play_button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="@string/main_play"
            android:textAllCaps="true"
            android:textSize="20sp"
            android:textColor="#000000"
            android:background="@drawable/play_button"
            app:backgroundTint="@null"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
        

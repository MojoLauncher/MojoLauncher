<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <!-- ── Header bar: back arrow | profile name - Mods | + | ⋮ ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_52sdp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/padding_medium">

        <ImageButton
            android:id="@+id/manage_mods_back"
            android:layout_width="@dimen/_38sdp"
            android:layout_height="@dimen/_38sdp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back_white"
            android:contentDescription="@string/global_back" />

        <TextView
            android:id="@+id/manage_mods_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/padding_moderate"
            android:textColor="@color/primary_text"
            android:textStyle="bold"
            android:textSize="@dimen/_14ssp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mcl_button_manage_mods" />

        <ImageButton
            android:id="@+id/manage_mods_add"
            android:layout_width="@dimen/_38sdp"
            android:layout_height="@dimen/_38sdp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add"
            android:contentDescription="@string/global_add" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/_1sdp"
        android:background="@color/divider" />

    <!-- Mod list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/manage_mods_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="@dimen/fragment_padding_medium"
        android:paddingVertical="@dimen/padding_medium"
        android:clipToPadding="false" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/manage_mods_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/secondary_text"
        android:textSize="@dimen/_13ssp"
        android:visibility="gone"
        android:text="@string/manage_mods_empty" />

</LinearLayout>

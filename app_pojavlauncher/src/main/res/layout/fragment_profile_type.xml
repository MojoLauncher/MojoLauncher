<?xml version="1.0" encoding="utf-8"?>
<com.kdt.DefocusableScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/fragment_padding_medium"
        android:orientation="vertical">

        <!-- Vanilla like version -->
        <TextView
            android:id="@+id/title_textview"
            style="@style/TextAppearance.AppCompat.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_profile_vanilla_like_versions"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/padding_large" />

        <View
            android:id="@+id/view"
            style="@style/ThickDivider"
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/padding_large" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/padding_large">

            <com.kdt.mcgui.MineButton
                android:id="@+id/vanilla_profile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/padding_small"
                android:text="@string/create_instance_vanilla" />

            <com.kdt.mcgui.MineButton
                android:id="@+id/optifine_profile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/padding_small"
                android:text="@string/mod_dl_install_optifine" />
        </LinearLayout>

        <!-- Modded versions -->
        <TextView
            android:id="@+id/title_modded_textview"
            style="@style/TextAppearance.AppCompat.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/padding_extra_extra_large"
            android:text="@string/create_profile_modded_versions" />

        <View
            android:id="@+id/view_modded"
            style="@style/ThickDivider"
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/padding_large" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/padding_large">

            <com.kdt.mcgui.MineButton
                android:id="@+id/modded_profile_fabric"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/padding_small"
                android:text="@string/modloader_dl_install_fabric_instance" />

            <com.kdt.mcgui.MineButton
                android:id="@+id/modded_profile_quilt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/padding_small"
                android:text="@string/modloader_dl_install_quilt_instance" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/padding_large">

            <com.kdt.mcgui.MineButton
                android:id="@+id/modded_profile_legacy_fabric"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/padding_small"
                android:text="@string/modloader_dl_install_legacy_fabric_instance" />

            <com.kdt.mcgui.MineButton
                android:id="@+id/modded_profile_forge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/padding_small"
                android:text="@string/modloader_dl_install_forge_instance" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/padding_large">

            <com.kdt.mcgui.MineButton
                android:id="@+id/modded_profile_neoforge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/padding_small"
                android:text="@string/modloader_dl_install_neoforge_instance" />

            <com.kdt.mcgui.MineButton
                android:id="@+id/modded_profile_modpack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/padding_small"
                android:text="@string/modpack_install_instance_button" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_large">

            <com.kdt.mcgui.MineButton
                android:id="@+id/modded_profile_bta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/padding_small"
                android:text="@string/create_bta_instance" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/padding_small" />
        </LinearLayout>

    </LinearLayout>
</com.kdt.DefocusableScrollView>

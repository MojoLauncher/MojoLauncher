<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="seekBarIncrement" format="integer" />
    <declare-styleable name="CustomSeekbar">
        <attr name="seekBarIncrement" />
        <!-- Redefine to be able to fetch the value -->
        <attr name="android:min" />
    </declare-styleable>

    <declare-styleable name="ExtendedTextView">
        <attr name="drawableStartSize" format="dimension" />
        <attr name="drawableEndPadding" format="dimension" />
        <attr name="drawableStartIntegerScaling" format="boolean" />
    </declare-styleable>
</resources>
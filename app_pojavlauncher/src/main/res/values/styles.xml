<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">
    <!-- Light or not? -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/background_app</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.App</item>

        <item name="android:textSize">@dimen/_13ssp</item>

        <!-- Material 3 Expressive properties -->
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.LargeComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.MediumComponent</item>

        <!-- Material 3 Color Palette Overrides -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/background_overlay</item>
        <item name="colorOnPrimaryContainer">@color/primary_text</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/divider</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/secondary_text</item>
        <item name="colorOutline">@color/primary</item>
        <item name="colorAccent">@color/primary</item>

        <!-- Alert Dialog Customization -->
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="materialAlertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="android:dialogTheme">@style/AppAlertDialogTheme</item>

        <!-- Spinner and Popup Customization -->
        <item name="android:spinnerStyle">@style/AppSpinnerStyle</item>
        <item name="android:listPopupWindowStyle">@style/AppListPopupWindowStyle</item>

        <!-- Fullscreen / Notch support -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="AppAlertDialogTheme" parent="Theme.Material3.DayNight.Dialog.Alert">
        <!-- Use the rounded drawable as the window background to ensure it shows up -->
        <item name="android:windowBackground">@drawable/dialog_background_rounded</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>

        <!-- Set internal background to transparent to avoid "two bg" glitch -->
        <item name="android:background">@drawable/dialog_background_rounded</item>
        <item name="backgroundTint">@android:color/transparent</item>

        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <item name="buttonBarPositiveButtonStyle">@style/App.Button.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/App.Button.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/App.Button.Dialog</item>
    </style>

    <style name="AppDialogActivityTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@drawable/dialog_background_rounded</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>

        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="materialAlertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="android:dialogTheme">@style/AppAlertDialogTheme</item>
    </style>

    <style name="AppSpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:popupBackground">@drawable/dialog_background_rounded</item>
    </style>

    <style name="AppListPopupWindowStyle" parent="Widget.Material3.PopupMenu.ListPopupWindow">
        <item name="android:popupBackground">@drawable/dialog_background_rounded</item>
    </style>

    <style name="App.Button.Dialog" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary_text</item>
    </style>

    <style name="PreferenceThemeOverlay.App" parent="PreferenceThemeOverlay.v14.Material">
        <item name="preferenceStyle">@style/AppPreference</item>
        <item name="preferenceCategoryStyle">@style/AppPreferenceCategory</item>
        <item name="switchPreferenceCompatStyle">@style/AppPreference.Switch</item>
        <item name="seekBarPreferenceStyle">@style/AppPreference.SeekBar</item>
    </style>

    <style name="AppPreference" parent="Preference">
        <item name="android:background">@drawable/preference_item_background</item>
        <item name="android:layout">@layout/app_preference_layout</item>
    </style>

    <style name="AppPreference.Switch" parent="Preference.SwitchPreferenceCompat">
        <item name="android:background">@drawable/preference_item_background</item>
        <item name="android:layout">@layout/app_preference_layout</item>
    </style>

    <style name="AppPreference.SeekBar" parent="Preference.SeekBarPreference">
        <item name="android:background">@drawable/preference_item_background</item>
        <item name="android:layout">@layout/app_preference_layout</item>
    </style>

    <style name="AppPreferenceCategory" parent="Preference.Category">
        <item name="android:layout">@layout/app_preference_category_layout</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
    </style>

    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="LauncherFragment_Divider">
        <item name="android:layout_width">@dimen/padding_tiny</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <style name="LauncherMenuButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:background">?android:attr/selectableItemBackground</item>
        <item name="android:textColor">@color/primary_text</item>
    </style>

    <style name="LauncherMenuButton.Universal" parent="LauncherMenuButton">
        <item name="android:layout_height">@dimen/_76sdp</item>
    </style>

    <style name="ThickDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_1sdp</item>
        <item name="android:background">?android:attr/listDivider</item>
    </style>

    <item name="dimension_tracker" type="id" />
    <style name="DimensionTracker">
        <item name="android:id">@id/dimension_tracker</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>
</resources>

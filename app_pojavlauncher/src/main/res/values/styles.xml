<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light or not? -->
    <style name="BaseAppTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>

        <item name="android:textSize">@dimen/_12ssp</item>

        <item name="colorControlButton">@color/control_button_color</item>
        <item name="colorControlButtonPressed">@color/control_button_pressed_color</item>

        <item name="colorMineButton">@color/minebutton_color</item>
        <item name="colorBackgroundApp">@color/background_app</item>
        <item name="colorDivider">@color/divider</item>
        <item name="colorBackgroundOverlay">@color/background_overlay</item>
        <item name="colorBackgroundStatusBar">@color/background_status_bar</item>
        <item name="colorBackgroundBottomBar">@color/background_bottom_bar</item>
        <item name="colorIconOutline">@color/icon_outline_color</item>

        <item name="colorPrimaryText">@color/primary_text</item>
        <item name="colorSecondaryText">@color/secondary_text</item>
    </style>
    <style name="AppTheme" parent="BaseAppTheme" />

    <style name="BaseMidnightTheme" parent="AppTheme">
        <item name="windowActionBar">true</item>
        <item name="android:textSize">@dimen/_16ssp</item>
    </style>
    <style name="MidnightTheme" parent="BaseMidnightTheme" />

    <style name="BaseAmethystTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>

        <item name="android:textSize">@dimen/_12ssp</item>

        <item name="colorControlButton">#4CC4C4C4</item>
        <item name="colorControlButtonPressed">#4D000000</item>

        <item name="colorMineButton">#9640b8</item>
        <item name="colorBackgroundApp">#181818</item>
        <item name="colorDivider">#464646</item>
        <item name="colorBackgroundOverlay">#464646</item>
        <item name="colorBackgroundStatusBar">#232323</item>
        <item name="colorBackgroundBottomBar">#232323</item>
        <item name="colorIconOutline">#232323</item>

        <item name="colorPrimaryText">#FFFFFF</item>
        <item name="colorSecondaryText">#B2B2B2</item>
    </style>

    <style name="AmethystTheme" parent="BaseAmethystTheme" />

    <style name="LauncherFragment_Divider">
        <item name="android:layout_width">@dimen/padding_tiny</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:background">?attr/colorDivider</item>
    </style>

    <style name="LauncherMenuButton" parent="Widget.AppCompat.Button">
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <style name="LauncherMenuButton.Universal" parent="LauncherMenuButton">
        <item name="android:layout_height">@dimen/_66sdp</item>
    </style>

    <style name="ThickDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_1sdp</item>
        <item name="android:background">?android:attr/listDivider</item>
    </style>

    <item name="dimension_tracker" type="id" />
    <style name="DimensionTracker">
        <item name="android:id">@id/dimension_tracker</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>
</resources>

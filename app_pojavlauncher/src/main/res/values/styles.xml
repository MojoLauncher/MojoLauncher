<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Default (Copper) ─────────────────────────────────── -->
    <style name="AppTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">#181818</item>
        <item name="android:navigationBarColor">#181818</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="colorBgApp">#181818</item>
        <item name="colorBgBottomBar">#181818</item>
        <item name="colorBgStatusBar">#181818</item>
        <item name="colorDivider">#464646</item>
        <item name="copperAccent">@color/minebutton_color</item>
        <item name="colorTextPrimary">@color/primary_text</item>
        <item name="colorTextSecondary">@color/secondary_text</item>
        <item name="bgMainDrawable">#181818</item>
        <item name="android:windowBackground">#181818</item>
        <item name="colorAccent">#ff5900</item>
    </style>
    <style name="AppTheme.Gradient">
        <item name="bgMainDrawable">@drawable/bg_gradient_copper</item>
        <item name="android:windowBackground">@drawable/bg_gradient_copper</item>
        <item name="colorBgBottomBar">@color/cu_bg_bottom_bar</item>
        <item name="colorBgStatusBar">@color/cu_bg_status_bar</item>
        <item name="colorAccent">#ff5900</item>
    </style>

